<section class="section pan {{#if pan.isSlaved}}slaved{{else}}master{{/if}}" style="margin-top: 20px">
  <header class="section-head">
    <h2 class="section-title">
      {{ localize 'shadowrun6.section.pan.title' }}
    </h2>
  </header>

  <div class="pan-summary">

    <div class="pan-summary-row">
      <i class="fas fa-user"></i>
      <span class="pan-summary-label">{{ localize 'shadowrun6.section.persona.title' }}</span>
      <strong>{{pan.persona.name}}</strong>
      <span class="pan-access pan-access-{{pan.access}}">{{ localize (concat 'shadowrun6.matrix.accessLevel.' pan.access)}}</span>
    </div>

    <div class="pan-summary-row">
      <i class="fas fa-laptop-code"></i>
      <span class="pan-summary-label">creates Persona</span>
      <strong>{{pan.accessDevice.name}}</strong>
      <span class="pan-muted">creates Persona</span>
    </div>

    {{#if pan.isSlaved}}
      <div class="pan-summary-row pan-slaved">
        <i class="fas fa-link"></i>

        <span class="pan-summary-label">
          {{ localize 'shadowrun6.section.pan.slavedTo' }}
        </span>

        <strong>{{pan.master.name}}</strong>

        <span class="pan-muted">
          {{pan.master.summary}}
        </span>
      </div>
    {{/if}}

    <div class="pan-summary-row">
      <i class="fas fa-shield-alt"></i>

      <span class="pan-summary-label">
        {{ localize 'shadowrun6.section.pan.defense' }}
      </span>

      <strong>{{pan.defenseProvider.name}}</strong>

      <span class="pan-muted">
        {{#if pan.isSlaved}}
          {{ localize 'shadowrun6.section.pan.usesMasterDefense' }}
        {{else}}
          {{ localize 'shadowrun6.section.pan.usesOwnDefense' }}
        {{/if}}
      </span>
    </div>
  </div>

  <div class="section-header">
    <div>{{ localize 'shadowrun6.section.pan.column.nodes' }}</div>
    <div>{{ localize 'shadowrun6.section.pan.column.access' }}</div>
    <div>{{ localize 'shadowrun6.label.column.action' }}</div>
  </div>

  <ol class="section-list pan-tree">
    {{#each pan.nodes as |node|}}
      <li
        class="section-item pan-node pan-node-{{node.kind}} {{#if node.isOwn}}pan-node-own{{/if}}"
        {{#if node.itemId}}
          data-item-id="{{node.itemId}}"
          data-document-class="Item"
        {{/if}}
      >
        <div class="section-row">
          <div
            class="section-name pan-tree-name {{#if node.draggable}}draggable{{/if}}"
            {{#if node.draggable}}
              data-item-id="{{node.itemId}}"
              draggable="true"
            {{/if}}
          >
            <i class="{{node.icon}} pan-node-icon"></i>

            <span class="pan-node-name">
              {{node.name}}
            </span>

            <span class="pan-role">
              {{node.roleLabel}}
            </span>
          </div>

          <div class="section-column">
            <span class="pan-access pan-access-{{node.access}}">
              {{node.accessLabel}}
            </span>
          </div>

          <div class="section-column item-controls">
            {{#if node.rollType}}
              <a
                class="item-control"
                data-tooltip="{{node.rollTooltip}}"
                data-action="roll"
                data-roll-type="{{node.rollType}}"
                {{#if node.itemId}}data-item-id="{{node.itemId}}"{{/if}}
                {{#if node.uuid}}data-uuid="{{node.uuid}}"{{/if}}
              >
                <i class="fas fa-shield-alt"></i>
              </a>
            {{/if}}

            {{#if node.itemId}}
              <a
                class="item-control item-edit"
                data-tooltip="{{localize 'DOCUMENT.Update' type=(localize 'TYPES.Item.gear')}}"
                data-action="viewDoc"
              >
                <i class="fas fa-edit"></i>
              </a>

              {{#if node.canDelete}}
                {{#if @root.editMode}}
                  <a
                    class="item-control item-delete"
                    data-tooltip="{{localize 'DOCUMENT.Delete' type=(localize 'TYPES.Item.gear')}}"
                    data-action="deleteDoc"
                  >
                    <i class="fas fa-trash"></i>
                  </a>
                {{/if}}
              {{/if}}
            {{/if}}
          </div>
        </div>

        {{#if node.children}}
          <ol class="pan-children">
            {{#each node.children as |child|}}
              <li
                class="section-item pan-node pan-node-{{child.kind}} {{#if child.isOwn}}pan-node-own{{/if}}"
                {{#if child.itemId}}
                  data-item-id="{{child.itemId}}"
                  data-document-class="Item"
                {{/if}}
              >
                <div class="section-row">
                  <div
                    class="section-name pan-tree-name {{#if child.draggable}}draggable{{/if}}"
                    {{#if child.draggable}}
                      data-item-id="{{child.itemId}}"
                      draggable="true"
                    {{/if}}
                  >
                    <i class="{{child.icon}} pan-node-icon"></i>

                    <span class="pan-node-name">
                      {{child.name}}
                    </span>

                    <span class="pan-role">
                      {{child.roleLabel}}
                    </span>
                  </div>

                  <div class="section-column">
                    <span class="pan-access pan-access-{{child.access}}">
                      {{child.accessLabel}}
                    </span>
                  </div>

                  <div class="section-column item-controls">
                    {{#if child.rollType}}
                      <a
                        class="item-control"
                        data-tooltip="{{child.rollTooltip}}"
                        data-action="roll"
                        data-roll-type="{{child.rollType}}"
                        {{#if child.itemId}}data-item-id="{{child.itemId}}"{{/if}}
                        {{#if child.uuid}}data-uuid="{{child.uuid}}"{{/if}}
                      >
                        <i class="fas fa-shield-alt"></i>
                      </a>
                    {{/if}}

                    {{#if child.itemId}}
                      <a
                        class="item-control item-edit"
                        data-tooltip="{{localize 'DOCUMENT.Update' type=(localize 'TYPES.Item.gear')}}"
                        data-action="viewDoc"
                      >
                        <i class="fas fa-edit"></i>
                      </a>

                      {{#if child.canDelete}}
                        {{#if @root.editMode}}
                          <a
                            class="item-control item-delete"
                            data-tooltip="{{localize 'DOCUMENT.Delete' type=(localize 'TYPES.Item.gear')}}"
                            data-action="deleteDoc"
                          >
                            <i class="fas fa-trash"></i>
                          </a>
                        {{/if}}
                      {{/if}}
                    {{/if}}
                  </div>
                </div>

                {{#if child.children}}
                  <ol class="pan-children">
                    {{#each child.children as |device|}}
                      <li
                        class="section-item pan-node pan-node-{{device.kind}} {{#if device.isOwn}}pan-node-own{{/if}}"
                        {{#if device.itemId}}
                          data-item-id="{{device.itemId}}"
                          data-document-class="Item"
                        {{/if}}
                      >
                        <div class="section-row">
                          <div
                            class="section-name pan-tree-name {{#if device.draggable}}draggable{{/if}}"
                            {{#if device.draggable}}
                              data-item-id="{{device.itemId}}"
                              draggable="true"
                            {{/if}}
                          >
                            <i class="{{device.icon}} pan-node-icon"></i>

                            <span class="pan-node-name">
                              {{device.name}}
                            </span>

                            <span class="pan-role">
                              {{device.roleLabel}}
                            </span>
                          </div>

                          <div class="section-column">
                            <span class="pan-access pan-access-{{device.access}}">
                              {{device.accessLabel}}
                            </span>
                          </div>

                          <div class="section-column item-controls">
                            {{#if device.rollType}}
                              <a
                                class="item-control"
                                data-tooltip="{{device.rollTooltip}}"
                                data-action="roll"
                                data-roll-type="{{device.rollType}}"
                                {{#if device.itemId}}data-item-id="{{device.itemId}}"{{/if}}
                                {{#if device.uuid}}data-uuid="{{device.uuid}}"{{/if}}
                              >
                                <i class="fas fa-shield-alt"></i>
                              </a>
                            {{/if}}

                            {{#if device.itemId}}
                              <a
                                class="item-control item-edit"
                                data-tooltip="{{localize 'DOCUMENT.Update' type=(localize 'TYPES.Item.gear')}}"
                                data-action="viewDoc"
                              >
                                <i class="fas fa-edit"></i>
                              </a>

                              {{#if device.canDelete}}
                                {{#if @root.editMode}}
                                  <a
                                    class="item-control item-delete"
                                    data-tooltip="{{localize 'DOCUMENT.Delete' type=(localize 'TYPES.Item.gear')}}"
                                    data-action="deleteDoc"
                                  >
                                    <i class="fas fa-trash"></i>
                                  </a>
                                {{/if}}
                              {{/if}}
                            {{/if}}
                          </div>
                        </div>
                      </li>
                    {{/each}}
                  </ol>
                {{/if}}
              </li>
            {{/each}}
          </ol>
        {{/if}}
      </li>
    {{/each}}
  </ol>
</section>