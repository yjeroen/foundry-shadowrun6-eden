<!-- Sprite Powers: -->
<section class="section powers">
  <header class="section-head">
    <h2 class="section-title">
      {{ localize 'shadowrun6.section.spritepowers.title' }}
    </h2>

    {{#if @root.editMode}}
      <div class="item-controls">
        <a
          class="item-control item-create"
          title="{{localize 'DOCUMENT.New' type=(localize 'TYPES.Item.spritepower')}}"
          data-action="createDoc"
          data-document-class="Item"
          data-type="spritepower"
        >
          <i class="fas fa-plus"></i>
        </a>
      </div>
    {{/if}}
  </header>

  <div class="section-header">
    <div></div>
    <div>{{ localize 'shadowrun6.label.column.name' }}</div>
    <div>{{ localize 'shadowrun6.section.spells.column.sustained' }}</div>
    <div>{{ localize 'shadowrun6.label.column.action' }}</div>
  </div>

  <ol class="section-list">
    {{#each powers as |item id|}}
      <li
        class="section-item"
        data-item-id="{{item.id}}"
        data-document-class="Item"
      >
        <div class="section-row">
          <div class="section-column">
            <button
              type="button"
              class="item-desc-toggle {{#if (not item.system.description)}}collapsible closed empty{{else}}collapsible closed{{/if}}"
              {{#if item.system.description}}
                data-action="itemDescToggle"
                data-item-id="{{item.id}}"
                title="{{localize 'SR6.title.clickItemName'}}"
              {{/if}}
            >
              +
            </button>
          </div>

          <div class="section-name draggable" data-item-id="{{item.id}}" draggable="true">
            {{item.name}}
          </div>

          <div class="section-column">
            {{#if (eq item.system.duration 'sustained')}}
              {{!-- <label class="switch" title="{{localize 'shadowrun6.section.sustained.toggle'}}">
                <input
                  type="checkbox"
                  data-action="itemSustainToggle"
                  {{checked item.system.isSustained}}
                >
                <span class="shadowrun6-slider round"></span>
              </label> --}}
              <a 
                class="item-control item-toggle"
                data-action='itemSustainToggle'
                title="{{localize "shadowrun6.section.sustained.toggle"}}"
              >
                <i class='fas {{#if item.system.isSustained}}fa-toggle-on{{else}}fa-toggle-off{{/if}}'></i>
              </a>
            {{/if}}
          </div>

          <div class="section-column item-controls"> 
            <a
              class="item-control draggable"
              title="{{skillHint actor item.system.skill 'resonance'}}"
              data-action="roll"
              data-roll-type="item"
              data-item-id="{{item.id}}"
              data-uuid="{{item.uuid}}"
            >
              <i class="fas fa-dice-six"></i>
            </a>

            <a
              class="item-control item-edit"
              title="{{localize 'DOCUMENT.Update' type=(localize 'TYPES.Item.spritepower')}}"
              data-action="viewDoc"
            >
              <i class="fas fa-edit"></i>
            </a>

            {{#if @root.editMode}}
              <a
                class="item-control item-delete"
                title="{{localize 'DOCUMENT.Delete' type=(localize 'TYPES.Item.spritepower')}}"
                data-action="deleteDoc"
              >
                <i class="fas fa-trash"></i>
              </a>
            {{/if}}
          </div>
        </div>

        <section class="collapsible-content closed" data-item-id="{{item.id}}">
          <strong>{{ localize 'shadowrun6.item.description' }}</strong>
          <div>{{{item.system.description}}}</div>
        </section>
      </li>
    {{/each}}
  </ol>
</section>
<!-- /Sprite Powers -->


{{> "systems/shadowrun6-eden/templates/sheets/actor/matrix-section.hbs"}}


