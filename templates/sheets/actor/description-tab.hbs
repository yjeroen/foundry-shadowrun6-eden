{{! Description Tab }}
<section
  class='tab description scrollable {{tab.cssClass}}'
  data-group='primary'
  data-tab='description'
>

  <div class="section">
    <div class="section-head">
      <h2 class="section-title">{{systemFields.description.label}}</h2>
    </div>
    <div class="section-content">
      {{! Editors must receive enriched text data from getData to properly handle rolls, UUID links, etc. }}
      {{#if editMode}} 
        <prose-mirror name="system.description" data-document-uuid="{{actor.uuid}}" value="{{system.description}}" collaborate="true" toggled="true">
          {{{enrichedDescription}}}
        </prose-mirror>
      {{else}}
        <p>{{{enrichedDescription}}}&nbsp;</p>
      {{/if}}
    </div>
  </div>
  
{{#unless limited}}
  <div class="section">
    <div class="section-head" data-tooltip="SR6.Actor.base.FIELDS.notes.tooltip">
      <h2 class="section-title">{{systemFields.notes.label}}</h2>
    </div>
    <div class="section-content">
      {{! Editors must receive enriched text data from getData to properly handle rolls, UUID links, etc. }}
      {{#if editMode}} 
        <prose-mirror name="system.notes" data-document-uuid="{{actor.uuid}}" value="{{system.notes}}" collaborate="true" toggled="true">
          {{{enrichedNotes}}}
        </prose-mirror>
      {{else}}
        <p>{{{enrichedNotes}}}&nbsp;</p>
      {{/if}}
    </div>
  </div>
{{/unless}}
  
</section>